---
config:
  layout: elk
title: Hotel Reservation System
---
classDiagram
direction LR
    class Person {
	    #String name
	    #int id
		+Person(String name, int id)
		+printRole()* void
		+getName() String
		+getId() int
    }

    class Guest {
		-String phoneNumber
        +Guest(String name, int id, String phoneNumber)
        +getPhoneNumber() String
        +printRole() void
    }

    class Employee {
		-double salary
        +Employee(String name, int id, double salary)
        +getSalary() double
        +printRole() void
    }

    class Manager {
		-double bonus
        +Manager(String name, int id, double salary, double bonus)
        +getBonus() double
        +printRole() void
    }

    class Hotel {
	    -String name
	    -Manager manager
	    -Employee[] employees
	    -int employeesCount
	    -Room[] rooms
	    -Booking[] bookings
	    -int roomCount
	    -int bookingCount
	    -double totalRevenue
	    +Hotel(String name, int maxRooms, int maxBookings, Manager manager, int maxEmployees)
	    +addRoom(String type, double price) boolean
	    +addBooking(Guest guest, int numberOfNights, int roomNumber, Employee employee) boolean
	    +availableRooms() Room[]
	    +cancelBooking(int bookingId) boolean
	    +findRoom(int roomNumber, int index) Room
	    +findBooking(int bookingId, int index) Booking
	    +findGuestBookings(Guest guest) Booking[]
	    +archiveCompleteBookings() boolean
	    +getRevenue() double
		+getEmployees() Employee[]
	    +hireEmployee(Employee employee) boolean
	    +fireEmployee(Employee employee) boolean
    }

    class Room {
	    -double nightPrice
	    -String type
	    -int roomNumber
	    -boolean isAvailable
	    +Room(String type, double nightPrice, int roomNumber)
	    +toString() String
	    +bookRoom() boolean
	    +releaseRoom() boolean
	    +getRoomNumber() int
	    +getRoomType() String
	    +getPrice() double
    }

    class Booking {
	    -int bookingId
	    -Guest guest
	    -Room room
	    -int numberOfNights
	    -boolean isPaid
	    -boolean isCheckedOut
	    -Employee bookedBy
	    +Booking(int bookingId, Guest guest, Room room, int numberOfNights, Employee bookedBy)
	    +getRoom() Room
	    +getGuest() Guest
	    +getEmployee() Employee
	    +getIsPaid() boolean
	    +getIsCheckedOut() boolean
	    +toString() String
	    +payBill() boolean
	    +checkOut() boolean
	    +getPrice() double
    }

    class Billable {
	    getPrice() double
    }

	<<abstract>> Person
	<<interface>> Billable

    Person <|-- Guest
    Person <|-- Employee
    Employee <|-- Manager
    Hotel "1" *-- "1..*" Room
    Hotel "1" *-- "0..*" Booking
    Hotel "1" o-- "1" Manager
    Hotel "1" o-- "1..*" Employee
    Booking "0..*" o-- "1" Guest
    Booking "0..*" o-- "1" Room
    Booking "0..*" o-- "1" Employee
    Room ..> Billable
    Booking ..> Billable